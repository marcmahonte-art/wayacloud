# ─── Supabase Auth ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OAuth ───
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── App URLs (no trailing slash) ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Wasabi S3 ───
WASABI_ACCESS_KEY=your-access-key
WASABI_SECRET_KEY=your-secret-key
WASABI_BUCKET=wayacloud
WASABI_REGION=eu-central-1
WASABI_ENDPOINT=https://s3.eu-central-1.wasabisys.com

# ─── Payment (CinetPay) ───
CINETPAY_API_KEY=your-api-key
CINETPAY_SITE_ID=your-site-id
CINETPAY_SECRET_KEY=your-secret-key

# ─── SMS (Twilio) ───
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=your-phone-number

# ─── AI (Anthropic Claude) ───
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── SMTP / Email (Resend - configure in Supabase Dashboard) ───
# RESEND_API_KEY=re_your-api-key
